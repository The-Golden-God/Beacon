# Database
DATABASE_URL=postgresql://user:password@host/beacon

# Auth
BETTER_AUTH_SECRET=change-me-32-chars-minimum

# App
PORT=4000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# Claude / Anthropic
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-sonnet-4-6

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_SOLO=price_...
STRIPE_PRICE_AGENCY=price_...
STRIPE_PRICE_OFFICE=price_...

# Google OAuth (Gmail send)
GOOGLE_CLIENT_ID=...
GOOGLE_CLIENT_SECRET=...
GOOGLE_REDIRECT_URI=http://localhost:4000/api/gmail/callback

# Microsoft OAuth (Outlook send)
MICROSOFT_CLIENT_ID=...
MICROSOFT_CLIENT_SECRET=...
MICROSOFT_REDIRECT_URI=http://localhost:4000/api/outlook/callback

# Upstash Redis (rate limiting + BullMQ)
UPSTASH_REDIS_REST_URL=https://...
UPSTASH_REDIS_REST_TOKEN=...

# Sentry
SENTRY_DSN=https://...
